# ==========================================
# HotelFlow — Variables de Entorno
# Copia este archivo como .env y llena los valores
# ==========================================

# Puerto del servidor (solo desarrollo local)
PORT=5000

# URL de conexión a PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Secreto para firmar tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=tu_secreto_super_seguro_aqui

# Entorno de ejecución
NODE_ENV=production

# URL del frontend (para CORS en producción — ej: https://tu-app.vercel.app)
FRONTEND_URL=https://tu-app.vercel.app
